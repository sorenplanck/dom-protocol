#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PROTECTED_FILE=".dom-protected-files"

[ -f "$PROTECTED_FILE" ] || exit 0

changed="$(git diff --cached --name-only)"
[ -n "$changed" ] || exit 0

blocked=0

while IFS= read -r protected; do
  protected="$(printf '%s' "$protected" | sed 's/[[:space:]]*$//')"

  [ -z "$protected" ] && continue
  case "$protected" in \#*) continue ;; esac

  if printf '%s\n' "$changed" | grep -Fx "$protected" >/dev/null 2>&1; then
    echo "BLOCKED: protected DOM file staged for commit: $protected"
    blocked=1
  fi

  if printf '%s\n' "$changed" | grep -E "^${protected}/" >/dev/null 2>&1; then
    echo "BLOCKED: protected DOM directory staged for commit: $protected"
    blocked=1
  fi
done < "$PROTECTED_FILE"

if [ "$blocked" -eq 1 ]; then
  echo
  echo "Commit blocked."
  echo "Protected DOM files/directories were modified."
  echo "Manual review required."
  echo
  echo "Forbidden bypass:"
  echo "  git commit --no-verify"
  echo
  exit 1
fi

exit 0
