#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PROTECTED_FILE=".dom-protected-files"

[ -f "$PROTECTED_FILE" ] || exit 0

branch="$(git branch --show-current)"
remote_ref="origin/$branch"

if git rev-parse --verify "$remote_ref" >/dev/null 2>&1; then
  base="$(git merge-base HEAD "$remote_ref")"
  changed="$(git diff --name-only "$base"..HEAD)"
else
  changed="$(git diff --name-only HEAD~1..HEAD 2>/dev/null || true)"
fi

[ -n "$changed" ] || exit 0

blocked=0

while IFS= read -r protected; do
  protected="$(printf '%s' "$protected" | sed 's/[[:space:]]*$//')"

  [ -z "$protected" ] && continue
  case "$protected" in \#*) continue ;; esac

  if printf '%s\n' "$changed" | grep -Fx "$protected" >/dev/null 2>&1; then
    echo "BLOCKED: protected DOM file included in push: $protected"
    blocked=1
  fi

  if printf '%s\n' "$changed" | grep -E "^${protected}/" >/dev/null 2>&1; then
    echo "BLOCKED: protected DOM directory included in push: $protected"
    blocked=1
  fi
done < "$PROTECTED_FILE"

if [ "$blocked" -eq 1 ]; then
  echo
  echo "Push blocked."
  echo "Protected DOM files/directories were modified."
  echo "Manual review required before pushing."
  echo
  echo "Forbidden bypass:"
  echo "  git push --force"
  echo
  exit 1
fi

exit 0
