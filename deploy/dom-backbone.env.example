# DOM backbone local environment.
# Install as /etc/dom/backbone.env and adjust paths/ports for the VPS.
# Do not put wallet passwords, seed phrases, private keys, API tokens, or
# other secrets in this file.

# The dom-node binary defaults to Network::Testnet today. This backbone
# profile is for devnet/testnet operation, not finalized mainnet.
DOM_DATA_DIR=/var/lib/dom-backbone
DOM_NETWORK=testnet
DOM_P2P_LISTEN_ADDR=0.0.0.0:33370
DOM_LOG=info

# RPC remains disabled unless this variable is uncommented. The value
# "default" selects the authoritative Testnet loopback address 127.0.0.1:33373.
# DOM_RPC_LISTEN_ADDR=default

# Optional comma-separated bootstrap peers, for private devnet/testnet
# deployments where DNS seeds are not available.
# DOM_SEED_PEERS=198.51.100.10:33370,198.51.100.11:33370
